generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RenderStatus {
  PENDING
  PROCESSING
  DONE
  ERROR
}

enum CreditTxType {
  PURCHASE
  USAGE
  BONUS
  REFUND
}

enum RenderEventType {
  CREATED
  PROCESSING_STARTED
  COMPLETED
  FAILED
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  credits   Int      @default(0)

  resetPasswordTokenHash String?
  resetPasswordExpiresAt DateTime?

  renders   Render[]
  creditTxs CreditTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Render {
  id                String       @id @default(uuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id])

  originalImageUrl  String
  generatedImageUrl String?
  prompt            String?

  status            RenderStatus @default(PENDING)
  creditsUsed       Int          @default(0)

  traceId           String?       @default(uuid()) // correlação interna p/ logs e filas
  clientRequestId   String?
  providerJobId     String?
  providerRequestId String?
  startedAt         DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  errorCode         String?
  errorMessage      String?
  errorMeta         Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  events            RenderEvent[]
  @@index([userId, createdAt])
  @@index([traceId])
  @@index([clientRequestId])
  @@index([status, createdAt])
}

model RenderEvent {
  id          String          @id @default(uuid())
  renderId    String
  render      Render          @relation(fields: [renderId], references: [id], onDelete: Cascade)
  type        RenderEventType
  fromStatus  RenderStatus?
  toStatus    RenderStatus?
  message     String?
  meta        Json?
  createdAt   DateTime        @default(now())
  @@index([renderId, createdAt])
}

model CreditTransaction {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])

  type      CreditTxType
  amount    Int
  meta      Json?

  createdAt DateTime     @default(now())

  @@index([userId, createdAt])
}